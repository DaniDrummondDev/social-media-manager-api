###############################################################################
# Social Media Manager — Environment Variables
#
# SECURITY NOTES:
# - Generate all secrets before production deployment
# - Never commit real secrets to version control
# - Use a secrets manager in production (AWS Secrets Manager, Vault, etc.)
###############################################################################

# Application
APP_NAME="Social Media Manager"
APP_ENV=local
APP_KEY=                                    # REQUIRED: php artisan key:generate
APP_DEBUG=true                              # DEV: true | PRODUCTION: false
APP_URL=http://localhost:8080
APP_PORT=8080
APP_TIMEZONE=UTC
APP_LOCALE=pt_BR

# Database (via PgBouncer — connection pooling)
# SECURITY: Generate strong password with: openssl rand -base64 32
DB_CONNECTION=pgsql
DB_HOST=pgbouncer
DB_PORT=6432
DB_DATABASE=social_media_manager
DB_USERNAME=social_media
DB_PASSWORD=                                # REQUIRED: Generate secure password

# Database Direct (bypasses PgBouncer — for migrations, schema changes)
DB_DIRECT_HOST=postgres
DB_DIRECT_PORT=5432

# Redis (4 databases for isolation)
# SECURITY: Generate password with: openssl rand -base64 32
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                             # REQUIRED: Generate secure password
REDIS_CACHE_DB=0
REDIS_QUEUE_DB=1
REDIS_RATE_LIMIT_DB=2
REDIS_SESSION_DB=3

# Queue
QUEUE_CONNECTION=redis
HORIZON_PREFIX=social-media-horizon:

# Cache
CACHE_STORE=redis

# Session
# SECURITY: Always encrypt sessions and use secure cookies in production
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true                        # SECURITY: Encrypt session data
SESSION_SECURE_COOKIE=true                  # SECURITY: HTTPS-only cookies

# Mail (Mailpit for local development)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@socialmedia.local"
MAIL_FROM_NAME="${APP_NAME}"

# Storage (MinIO — S3 compatible)
# SECURITY: Generate credentials with:
#   MINIO_ROOT_USER=$(openssl rand -hex 16)
#   MINIO_ROOT_PASSWORD=$(openssl rand -base64 32)
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=                          # REQUIRED: Same as MINIO_ROOT_USER
AWS_SECRET_ACCESS_KEY=                      # REQUIRED: Same as MINIO_ROOT_PASSWORD
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=social-media
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# JWT Authentication (RS256)
# SECURITY: Generate RSA 4096-bit key pair:
#   ssh-keygen -t rsa -b 4096 -m PEM -f jwt.key -N ""
#   openssl rsa -in jwt.key -pubout -outform PEM -out jwt.key.pub
#   JWT_PRIVATE_KEY="$(cat jwt.key | base64 -w 0)"
#   JWT_PUBLIC_KEY="$(cat jwt.key.pub | base64 -w 0)"
JWT_SECRET=null
JWT_ALGO=RS256
JWT_PRIVATE_KEY=                            # REQUIRED: Base64-encoded RSA private key
JWT_PUBLIC_KEY=                             # REQUIRED: Base64-encoded RSA public key
JWT_TTL=15
JWT_REFRESH_TTL=43200

# Social Media Providers
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=${APP_URL}/api/v1/social-accounts/instagram/callback

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=${APP_URL}/api/v1/social-accounts/tiktok/callback

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=${APP_URL}/api/v1/social-accounts/youtube/callback

# AI Providers
AI_DEFAULT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
ANTHROPIC_API_KEY=

# Stripe (Billing)
STRIPE_KEY=                                 # pk_test_... or pk_live_...
STRIPE_SECRET=                              # sk_test_... or sk_live_...
STRIPE_WEBHOOK_SECRET=                      # whsec_... (from Stripe Dashboard → Webhooks)
STRIPE_TRIAL_DAYS=14                        # Free trial period for paid plans

# Stripe Price IDs (from Stripe Dashboard → Products → Prices)
STRIPE_PRICE_CREATOR_MONTHLY=price_1T8kTeK0TFrYT4C1gTZARb3x
STRIPE_PRICE_CREATOR_YEARLY=price_1T8kU6K0TFrYT4C1KcWVaSoy
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_1T8kUYK0TFrYT4C18m77Epoh
STRIPE_PRICE_PROFESSIONAL_YEARLY=price_1T8kUlK0TFrYT4C1fOYDyruK
STRIPE_PRICE_AGENCY_MONTHLY=price_1T8kVEK0TFrYT4C1oyGbdlFd
STRIPE_PRICE_AGENCY_YEARLY=price_1T8kVRK0TFrYT4C1Zgv2m9Oy

# Encryption (AES-256-GCM for social tokens)
# SECURITY: Generate with: openssl rand -base64 32
SOCIAL_TOKEN_ENCRYPTION_KEY=                # REQUIRED: 32-byte base64 key

# Encryption (AES-256-GCM for ad account tokens)
# SECURITY: Generate with: openssl rand -base64 32
AD_TOKEN_ENCRYPTION_KEY=                    # REQUIRED: 32-byte base64 key

# CRM Integrations
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# CRM Token Encryption (AES-256-GCM)
# SECURITY: Generate with: openssl rand -base64 32
CRM_TOKEN_ENCRYPTION_KEY=                   # REQUIRED: 32-byte base64 key for CRM tokens

# PgBouncer
PGBOUNCER_HOST=pgbouncer
PGBOUNCER_PORT=6432

# MinIO
# SECURITY: Generate credentials with:
#   MINIO_ROOT_USER=$(openssl rand -hex 16)
#   MINIO_ROOT_PASSWORD=$(openssl rand -base64 32)
MINIO_ROOT_USER=                            # REQUIRED: Random hex string
MINIO_ROOT_PASSWORD=                        # REQUIRED: Strong password

# Logging
# SECURITY: Use 'warning' or higher in production
LOG_CHANNEL=stack
LOG_LEVEL=debug                             # DEV: debug | PRODUCTION: warning
LOG_STACK=single

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORE=redis

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=120

# AI Agents Microservice (Python/LangGraph — ADR-021)
# SECURITY: Generate secret with: openssl rand -hex 32
AI_AGENTS_PORT=8001
AI_AGENTS_BASE_URL=http://ai-agents:8000
AI_AGENTS_INTERNAL_SECRET=                  # REQUIRED: 64-char hex string for auth
AI_AGENTS_POLL_TIMEOUT=120
AI_AGENTS_POLL_INTERVAL_MS=500
AI_AGENTS_LOG_LEVEL=info
AI_AGENTS_WORKERS=2

# Admin IP Whitelist (ADMIN-001 Security Fix)
# SECURITY: Comma-separated list of IPs or CIDR ranges allowed to access admin routes
# Examples:
#   Single IP: 192.168.1.100
#   Multiple IPs: 192.168.1.100,10.0.0.5
#   CIDR range: 192.168.1.0/24
#   Mixed: 192.168.1.100,10.0.0.0/24
# IMPORTANT: Leave empty only in development. MUST be set in production.
ADMIN_IP_WHITELIST=                         # REQUIRED in production: Comma-separated IPs/CIDRs

# Swagger/OpenAPI Documentation
SCRAMBLE_ENABLED=true                       # SECURITY: Set to false in production
