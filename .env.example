###############################################################################
# Social Media Manager — Environment Variables
###############################################################################

# Application
APP_NAME="Social Media Manager"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_PORT=8080
APP_TIMEZONE=UTC
APP_LOCALE=pt_BR

# Database (via PgBouncer — connection pooling)
DB_CONNECTION=pgsql
DB_HOST=pgbouncer
DB_PORT=6432
DB_DATABASE=social_media_manager
DB_USERNAME=social_media
DB_PASSWORD=secret

# Database Direct (bypasses PgBouncer — for migrations, schema changes)
DB_DIRECT_HOST=postgres
DB_DIRECT_PORT=5432

# Redis (4 databases for isolation)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_CACHE_DB=0
REDIS_QUEUE_DB=1
REDIS_RATE_LIMIT_DB=2
REDIS_SESSION_DB=3

# Queue
QUEUE_CONNECTION=redis
HORIZON_PREFIX=social-media-horizon:

# Cache
CACHE_STORE=redis

# Session
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Mail (Mailpit for local development)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@socialmedia.local"
MAIL_FROM_NAME="${APP_NAME}"

# Storage (MinIO — S3 compatible)
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=social-media
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# JWT Authentication (RS256)
JWT_SECRET=null
JWT_ALGO=RS256
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_TTL=15
JWT_REFRESH_TTL=43200

# Social Media Providers
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=${APP_URL}/api/v1/social-accounts/instagram/callback

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=${APP_URL}/api/v1/social-accounts/tiktok/callback

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=${APP_URL}/api/v1/social-accounts/youtube/callback

# AI Providers
AI_DEFAULT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
ANTHROPIC_API_KEY=

# Stripe (Billing)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Encryption (AES-256-GCM for social tokens)
SOCIAL_TOKEN_ENCRYPTION_KEY=

# Encryption (AES-256-GCM for ad account tokens)
AD_TOKEN_ENCRYPTION_KEY=

# CRM Integrations
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# PgBouncer
PGBOUNCER_HOST=pgbouncer
PGBOUNCER_PORT=6432

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_STACK=single

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORE=redis

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=120
