# ==============================================================================
# AI Agents Microservice — Environment Variables
# ==============================================================================
# Copy to .env and fill in values before running the service.
#
# SECURITY NOTES:
# - NEVER commit actual secrets to version control
# - Generate secrets with: openssl rand -hex 32
# - All secrets MUST be set in production
# ==============================================================================

# ------------------------------------------------------------------------------
# AI Provider Keys (REQUIRED)
# ------------------------------------------------------------------------------
# At least one provider key is required for LLM operations.
# OpenAI is used for content generation, Anthropic for analysis.
#
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ------------------------------------------------------------------------------
# Database (PostgreSQL — shared with Laravel)
# ------------------------------------------------------------------------------
# Connection string for the main PostgreSQL database.
# Should match Laravel's DB_* configuration.
DATABASE_URL=postgresql://social_media:secret@postgres:5432/social_media_manager

# ------------------------------------------------------------------------------
# Redis (DB 4 — dedicated for AI Agents)
# ------------------------------------------------------------------------------
# Redis is used for:
# - Job status storage
# - Rate limiting counters
# - LangGraph checkpoints
#
# NOTE: Uses DB 4 to isolate from Laravel's Redis usage (DB 0-3).
# IMPORTANT: In production, use Redis with authentication:
#   REDIS_URL=redis://:PASSWORD@redis:6379/4
REDIS_URL=redis://redis:6379/4

# ------------------------------------------------------------------------------
# Callback URL (Laravel internal endpoint)
# ------------------------------------------------------------------------------
# URL where pipeline results are POSTed when jobs complete.
# This should point to Laravel's internal callback handler.
CALLBACK_BASE_URL=http://nginx:80/api/v1/internal

# ------------------------------------------------------------------------------
# Internal Secret (REQUIRED IN PRODUCTION)
# ------------------------------------------------------------------------------
# Shared secret for service-to-service authentication.
# Laravel sends this in X-Internal-Secret header.
# AI Agents validates it before processing any request.
#
# Generate with: openssl rand -hex 32
#
# CRITICAL: This MUST be set in production. Without it:
# - Anyone can execute AI pipelines
# - No protection against unauthorized access
# - Potential for unlimited cost abuse
INTERNAL_SECRET=

# ------------------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------------------
# Log level: debug, info, warning, error, critical
LOG_LEVEL=info

# Number of Uvicorn workers (2 is good for development)
WORKERS=2

# Environment: development, staging, production
# In production, INTERNAL_SECRET is required.
ENVIRONMENT=development

# ------------------------------------------------------------------------------
# Rate Limiting (per organization, per minute)
# ------------------------------------------------------------------------------
# Limits on how many pipeline requests each organization can make.
# Helps prevent DoS attacks and control AI costs.
RATE_LIMIT_CONTENT_CREATION=10
RATE_LIMIT_CONTENT_DNA=5
RATE_LIMIT_SOCIAL_LISTENING=30
RATE_LIMIT_VISUAL_ADAPTATION=10
