{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "social-media-manager/api",
    "type": "project",
    "description": "Social Media Manager — API SaaS for scheduling, publishing and managing content across multiple social networks.",
    "keywords": ["social-media", "saas", "api", "laravel", "ddd"],
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "aws/aws-sdk-php": "^3.370",
        "bacon/bacon-qr-code": "^3.0",
        "echolabsdev/prism": "^0.99.19",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.0",
        "laravel/tinker": "^2.10.1",
        "pgvector/pgvector": "^0.2.2",
        "php-open-source-saver/jwt-auth": "^2.8",
        "pragmarx/google2fa": "^9.0"
    },
    "require-dev": {
        "dedoc/scramble": "^0.13",
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.5.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "App\\Domain\\": "app/Domain/",
            "App\\Application\\": "app/Application/",
            "App\\Infrastructure\\": "app/Infrastructure/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "analyse": [
            "@php vendor/bin/phpstan analyse"
        ],
        "format": [
            "@php vendor/bin/pint"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": ["pgvector/pgvector"]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
